{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "es5",
  "printWidth": 100,
  "endOfLine": "lf",
  "arrowParens": "always",
  "overrides": [
    {
      "files": "*.css",
      "options": { "singleQuote": false }
    },
    {
      "files": "*.html",
      "options": { "printWidth": 120 }
    }
  ]
}
