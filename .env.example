# =============================================================================
#  FinanzApp — Environment Variables (Overview)
# =============================================================================
#
#  This file is a TOP-LEVEL REFERENCE — it lists every variable the app uses
#  and what each one does. It is NOT directly consumed by the app.
#
#  To actually run the app locally, copy the per-package templates:
#
#     backend/.dev.vars.example  →  backend/.dev.vars
#     frontend/.env.local.example →  frontend/.env.local
#
#  The backend (Cloudflare Workers) reads .dev.vars at runtime via wrangler.
#  The frontend (Next.js) reads .env.local at build/run time.
#
#  None of the *.example files contain secrets — fill the real values in
#  the .dev.vars / .env.local files (both are gitignored).
# =============================================================================


# ─── Backend: Datenbank ───────────────────────────────────────────────────────

# Production: Cloudflare Hyperdrive binding (set in wrangler.toml, not here).
# Dev/Fallback: direct Postgres connection. Use Supabase Session-Pooler (port
# 5432), NOT the Transaction-Pooler (port 6543).
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# REST-API fallback when DATABASE_URL isn't reachable. The service_role key
# bypasses Row-Level-Security — never expose it to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ─── Backend: Session & Verification ──────────────────────────────────────────

# Auth-cookie lifetime in minutes. Default 180 (= 3 hours).
SESSION_TTL_MINUTES=180


# ─── Backend: E-Mail (Resend) ─────────────────────────────────────────────────

# Used to send registration and password-reset codes. Without it nobody can
# register. EMAIL_FROM must be a domain verified in your Resend account.
RESEND_API_KEY=re_your_key
EMAIL_FROM=FBM Finance <noreply@yourdomain.com>


# ─── Backend: Stock-Daten (Finnhub) ───────────────────────────────────────────

# Powers the stocks page: live quotes, search, historical charts. Free tier
# allows 60 calls/min — plenty for dev.
FINNHUB_API_KEY=your-finnhub-key


# ─── Backend: Firmen-Logos (logo.dev) ─────────────────────────────────────────

# Decorative logos next to stock tickers. The app still works without it,
# logos just don't show up.
LOGO_DEV_API_KEY=your-logo-dev-key


# ─── Backend: KI-Assistent (OpenRouter) ───────────────────────────────────────

# OpenRouter brokers requests to many LLM providers. Used by the "Finzbro"
# bot that auto-answers forum questions. OPENROUTER_API_KEY_2 is an optional
# fallback when the primary key hits its rate-limit.
OPENROUTER_API_KEY=your-key
OPENROUTER_API_KEY_2=your-fallback-key


# ─── Frontend ─────────────────────────────────────────────────────────────────

# Where the Next.js app expects the backend to live. The value is baked into
# the JS bundle at build time, so set it BEFORE you run `npm run build`.
NEXT_PUBLIC_API_URL=http://localhost:8787
