{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node16",
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "backend/**/*",
    "database/**/*",
    "frontend/**/*",
    "shared/**/*",
    "*.mjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
