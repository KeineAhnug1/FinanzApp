{
  "name": "finanzapp",
  "version": "1.0.0",
  "private": true,
  "description": "FinanzApp - PostgreSQL/Supabase Backend",
  "main": "backend/server.mjs",
  "scripts": {
    "start": "node backend/server.mjs",
    "backend:start": "node backend/server.mjs",
    "web:dev": "vite --config frontend/vite.config.ts",
    "web:build": "vite build --config frontend/vite.config.ts",
    "web:preview": "vite preview --config frontend/vite.config.ts",
    "dev": "concurrently \"npm run backend:start\" \"npm run web:dev\"",
    "db:check": "node database/check-connection.mjs",
    "db:clear": "node database/clear-database.mjs",
    "db:migrate": "node database/migrate-to-supabase.mjs",
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "dotenv": "^17.2.4",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
