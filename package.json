{
  "name": "finanzapp",
  "version": "1.0.0",
  "private": true,
  "description": "MongoDB schema setup for FinanzApp",
  "main": "database/schema-setup.js",
  "scripts": {
    "schema:setup": "node database/schema-setup.js",
    "import:testdata": "node database/seed-reset.mjs",
    "seed:reset": "node database/seed-reset.mjs",
    "db:wipe": "node database/wipe-data.mjs",
