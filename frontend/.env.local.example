# =============================================================================
#  FinanzApp Frontend — Local Development Environment
# =============================================================================
#
#  HOW TO USE
#  ----------
#  1. Copy this file:  cp .env.local.example .env.local
#  2. Adjust the value below if your backend runs on a different port.
#  3. .env.local is gitignored — safe to put real values in.
#
#  Next.js reads .env.local automatically (no extra config). Variables that
#  start with NEXT_PUBLIC_ are baked into the client bundle at build time
#  and visible in the browser — DON'T put secrets here.
# =============================================================================


# ─── Backend-Endpoint ─────────────────────────────────────────────────────────
#
# Where this Next.js app expects the Hono/Workers backend to live.
#
# Wrangler defaults the backend to port 8787 (`npm run dev --prefix backend`),
# so the value below works out-of-the-box. In production set this to your
# deployed Worker URL, e.g. https://finanzapp-backend.<sub>.workers.dev
# or https://api.finanzapp.example.com.
#
# IMPORTANT: this is baked into the JS bundle at build time. If you change it
# you must re-run `npm run build` (or restart the dev server).
#
NEXT_PUBLIC_API_URL=http://localhost:8787
